From: Grant Hess <granthess96@gmail.com>
Date: Tue, 10 Mar 2026 14:00:00 -0000
Subject: [PATCH] gnulib-tests: initialize AM_CFLAGS for Automake 1.18+

Automake 1.18.1 strictly enforces that variables must be initialized
with '=' before being appended to with '+='. This prevents an error
when gnulib.mk is included.

--- a/gnulib-tests/Makefile.am
+++ b/gnulib-tests/Makefile.am
@@ -1,3 +1,6 @@
+AM_CFLAGS =
+AM_CPPFLAGS =
+AM_LDFLAGS =
 include gnulib.mk
 
 AM_CFLAGS += $(GNULIB_TESTS_CFLAGS)